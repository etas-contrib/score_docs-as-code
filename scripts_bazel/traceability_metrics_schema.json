{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eclipse-score.github.io/docs-as-code/traceability-metrics-schema.json",
  "title": "Traceability Metrics Schema",
  "description": "Schema for traceability metrics generated by the documentation build.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_by",
    "overall_metrics",
    "metrics_by_type",
    "tests"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2",
      "description": "Version of this metrics schema."
    },
    "generated_by": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the producer that generated this metrics file."
    },
    "overall_metrics": {
      "$ref": "#/$defs/requirementMetrics"
    },
    "metrics_by_type": {
      "type": "object",
      "description": "Mapping from need type (for example, tool_req) to requirement metrics.",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/requirementMetrics"
      },
      "propertyNames": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests": {
      "$ref": "#/$defs/testMetrics"
    }
  },
  "$defs": {
    "requirementMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "with_code_link",
        "with_test_link",
        "fully_linked",
        "with_code_link_pct",
        "with_test_link_pct",
        "fully_linked_pct"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "with_code_link": {
          "type": "integer",
          "minimum": 0
        },
        "with_test_link": {
          "type": "integer",
          "minimum": 0
        },
        "fully_linked": {
          "type": "integer",
          "minimum": 0
        },
        "with_code_link_pct": {
          "$ref": "#/$defs/percentage"
        },
        "with_test_link_pct": {
          "$ref": "#/$defs/percentage"
        },
        "fully_linked_pct": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "testMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "linked_to_requirements",
        "linked_to_requirements_pct",
        "broken_references"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "linked_to_requirements": {
          "type": "integer",
          "minimum": 0
        },
        "linked_to_requirements_pct": {
          "$ref": "#/$defs/percentage"
        },
        "broken_references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/brokenReference"
          }
        }
      }
    },
    "brokenReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "testcase",
        "missing_need"
      ],
      "properties": {
        "testcase": {
          "type": "string",
          "minLength": 1
        },
        "missing_need": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  }
}
